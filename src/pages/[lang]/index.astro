---
import Layout from '../../layouts/Layout.astro';
import content from '../../data/site-content.json';
import type { Lang } from '../../i18n/config.i18n';
import HeroHome from '../../components/home/hero/hero_home.astro';
import Legacy from '../../components/home/sections/Legacy.astro';

const lang = Astro.params.lang as Lang;
const data = content[lang];

if (!(lang in content)) {
    return Astro.redirect('/404');
}
---

<Layout title={data.brandName} lang={lang}>
    <HeroHome lang={lang} />
    <Legacy lang={lang} />

    <div class="min-h-screen flex flex-col items-center justify-center relative p-6">
        
        <div class="relative group mb-20">
            <div class="absolute inset-0 bg-gradient-to-r from-[#21D4ED] to-[#AF25FD] blur-2xl opacity-30 group-hover:opacity-50 transition-opacity duration-500 rounded-full"></div>
            <img 
                src="/icono_real.png" 
                alt="Logo Flotante" 
                class="relative w-48 h-48 md:w-64 md:h-64 object-contain animate-float"
            />
            <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 w-3/4 h-4 bg-black/40 blur-md rounded-full animate-shadow"></div>
        </div>
        <h1 class="text-gray-400 text-center">
            {data.autroui.title}
        </h1>
    </div>
</Layout>