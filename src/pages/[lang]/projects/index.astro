---
import type { Lang } from "../../../i18n/config.i18n";
import Layout from "../../../layouts/Layout.astro";
import content from "../../../data/site-projects-content.json"
import Filters from "../../../components/projects/sections/Filters.astro";
import Projects from "../../../components/projects/sections/Projects.astro";
import { actions } from "astro:actions";

const { searchParams } = Astro.url
const category = searchParams.get('category') || 'all'
const filter = searchParams.get('search') || ""

const lang = Astro.params.lang as Lang

const dataProjects = content[lang]

const { data, error } = await Astro.callAction(actions.getProjects, {category, lang,filter})

const projects = data?.data || []


const currentCategoryName = dataProjects.projects.categories.find(c => c.path === category)?.category || category;

const categoryTitle = category !== 'all' ? `${currentCategoryName} | ` : '';
const seoTitle = `${categoryTitle}${dataProjects.brandName}`;

let seoDescription = dataProjects.seo.defaultDescription;

if (category !== 'all') {
    seoDescription = dataProjects.seo.categoryDescription.replace('{category}', currentCategoryName);
}

const itemListSchema = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "itemListElement": projects.slice(0, 10).map((project, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "url": new URL(`/${lang}/projects/${project.slug}`, Astro.url.origin).href,
        "name": project.name
    }))
};
---

<Layout title={seoTitle} lang={lang} description={seoDescription} schema={itemListSchema}>
    <Filters lang={lang} categoryName={category} searhName={filter} />
    <Projects lang={lang} projects={projects} categoryName={category} />
</Layout>