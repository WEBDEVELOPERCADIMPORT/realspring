---
import type { Lang } from "../../../i18n/config.i18n";
import Layout from "../../../layouts/Layout.astro";
import content from "../../../data/site-projects-content.json"
import Filters from "../../../components/projects/sections/Filters.astro";
import Projects from "../../../components/projects/sections/Projects.astro";
import { actions } from "astro:actions";

const lang = Astro.params.lang as Lang

const dataProjects = content[lang]

const { data, error } = await Astro.callAction(actions.getProjects, {})

const projects = data?.data || []

---

<Layout title={dataProjects.brandName} lang={lang}>
    <Filters lang={lang}/>
    <Projects lang={lang} projects={projects} />

</Layout>