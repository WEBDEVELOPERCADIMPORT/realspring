---
import { MapPin } from 'lucide-astro'
import content from '../../../data/site-projects-detail-content.json'
import type { Amenities, Project } from '../../../domains/project.interface'
import type { Lang } from '../../../i18n/config.i18n'
import { getIconAmenities } from '../../projects/components/getIconAmenities'

interface Props {
    lang: Lang
    amenities: Amenities[] | null | undefined
}


const { lang, amenities } = Astro.props


const data = content[lang].amenities
---


<section id="amenities"  class="bg-gray-real w-full "> 

    <div class="flex flex-col gap-10 px-10 justify-start h-full bg-gray-real">   
        <h2 class="relative text-blue-real text-1xl font-alexandria font-medium ">
            {data.title}
            <div class="w-30 h-1 bg-red-real "></div>  
        </h2>
        <div class="relative grid grid-col-2 xl:grid-cols-4 w-full overflow-auto gap-3">
        {
                amenities && amenities.map( item => {
                    const itemIcon = getIconAmenities(item.key)
                    return (
                        <div class="text-blue-real font-bold flex gap-5 items-center justify-between bg-white-real p-5 border-l-5 border-l-red-real hover:shadow-2xl transition-shadow duration-300 " >
                            <itemIcon.icon size={20} />
                            <h4 class="text-black-real font-bold">
                                {item.amount} {itemIcon.label[lang]}
                            </h4>
                        </div>
                    )
                })
            }
        </div>
    </div>

</section>