---
interface Props {
    date: string
    title: string
    paragraph: string
    squareColor?: string 
}

const { date, title, paragraph, squareColor = "blue-real" } = Astro.props
---

<div class="relative border-l-3 border-l-gray-real px-10 flex flex-col">
    <div class={`absolute top-0 left-0 w-4 h-4 bg-${squareColor} -translate-x-1/2`}></div>  
    <h3 class="text-blue-real font-bold text-3xl m-2">
        {date}
    </h3>
    <p class="text-2xl font-bold mb-2">
        {title}
    </p>
    <p class="font-alexandria text-gray-500 ">
        {paragraph}
    </p>
</div>