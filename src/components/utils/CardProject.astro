---
import { BedDouble, MapPin } from "lucide-astro";
import type { Project } from "../../domains/project.interface";
import { getIconAmenities } from "../projects/components/getIconAmenities";

interface Props {
    project: Project;
    color?: string;
    lang: string
}

const { project, color = "blue-real", lang} = Astro.props

---

<div class="w-full flex flex-col hover:shadow-2xl transition-all duration-300">
    <div class="flex w-full object-cover relative">
        <a href=`/${lang}/projects/${project.slug}` class="w-full">
            <img src={project.image} class="w-full transition-transform duration-500 ease-in-out hover:scale-105 hover:shadow-2xl" alt="">
            <div class="absolute right-0 bottom-0 bg-white-real text-blue-real font-bold text-2xl p-3 ">
                ${project.price}
            </div>
        </a>
    </div>
    <div class=`flex flex-col w-full gap-3 border-l-3 border-l-${color} p-2`>
        <h3 class="text-black-real font-bold text-2xl">
            {project.name}
        </h3>
        <p class="flex flex-row items-center">
            <MapPin size={15} />
            {project.location}
        </p>
        <div class="flex justify-between items-center p-3">
            {
                project.amenities && project.amenities.slice(0,3).map( item => {
                    const itemIcon = getIconAmenities(item.key)
                    return (
                        <div class="text-blue-real font-bold flex gap-2 items-center" >
                            <itemIcon.icon size={20} />
                            <h4 class="text-black-real font-bold">
                                {item.amount} {itemIcon.label}
                            </h4>
                        </div>
                    )
                })
            }
        </div>
    </div>
</div>