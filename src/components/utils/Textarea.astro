---
import type { HTMLAttributes } from 'astro/types';


interface Props extends HTMLAttributes<'textarea'> {
    label: string
    color?: string
    ref:   string
}

const { label, color = "blue-real", ref, ...rest  } = Astro.props;
---


<div class="flex flex-col">
    <label for={ref} class=`text-${color} font-bold`>
        {label}
    </label>
    <textarea id={ref} name={ref} {...rest}  class="bg-gray-real inset-shadow-sm p-2">

    </textarea>
</div>