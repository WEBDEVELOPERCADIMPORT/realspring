---
import type { Lang } from '../../i18n/config.i18n';
import { Globe, Flag } from 'lucide-astro'

interface Props {
    lang: Lang
}

const { lang } = Astro.props;

const currentPath = Astro.url.pathname;
const switchLangPath = lang === "es"
    ? currentPath.replace("/es", "/en")
    : currentPath.replace("/en", "/es");

const select = "flex justify-center gap-1 items-center bg-white border-l-3  border-l-red-real w-full text-center text-blue-real font-bold "
const notSelect = "flex justify-center items-center gap-1 text-gray-600 font-bold w-full text-center"

const onStyle = (alang: string) => {

    return alang == lang ? select : notSelect
}
---

<div class="w-30 flex justify-center gap-3 p-1  shadow-2xl bg-gray-100 inset-shadow-sm ">
    <a href={switchLangPath} class={onStyle('es')}>
        <Globe size="12"  />
        Es
    </a>
    <a href={switchLangPath} class={onStyle('en')}>
        <Flag size="12" />
        En
    </a>
</div>